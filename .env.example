VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional feed overrides
# Optional: only set this if you deploy your own RSS proxy. Static Amplify can leave this blank.
VITE_RSS_LOCAL_PROXY_URL=
# Optional: rss2json is used by default in production when no local proxy is configured.
VITE_RSS_PROVIDER_URL=
# Optional: only needed if you want rss2json to honor custom count limits.
VITE_RSS2JSON_API_KEY=
# Optional: raw RSS proxy fallback. Leave blank unless you operate a CORS-safe proxy.
VITE_RSS_RAW_PROXY_URL=
