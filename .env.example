VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional first-party news API. Leave blank/unset in deployments until the API is deployed;
# article sections will fall back to browser-side RSS fetching.
# VITE_NEWS_API_URL=https://ntqzmx2vo55fnwkqfwggcmdkny0jzlco.lambda-url.us-east-2.on.aws/health
VITE_NEWS_API_URL=https://ntqzmx2vo55fnwkqfwggcmdkny0jzlco.lambda-url.us-east-2.on.aws/health

# Optional RSS fallback overrides. Defaults use rss2json.com in production.
# VITE_RSS_PROVIDER_URL=https://api.rss2json.com/v1/api.json
RSS_2_API=
# Legacy alias still supported:
# VITE_RSS2JSON_API_KEY=
# VITE_RSS_LOCAL_PROXY_URL=
# VITE_RSS_RAW_PROXY_URL=
